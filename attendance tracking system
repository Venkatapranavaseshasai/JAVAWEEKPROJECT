import java.io.*;
import java.time.LocalDate;
import java.util.*;

 
class Student {
    int id;
    String name;
    HashMap<LocalDate, Boolean> attendance;

    Student(int id, String name) {
        this.id = id;
        this.name = name;
        this.attendance = new HashMap<>();
    }

    void markAttendance(boolean present) {
        attendance.put(LocalDate.now(), present);
    }

    void showReport() {
        int present = 0;
        for (boolean status : attendance.values()) {
            if (status) present++;
        }

        int total = attendance.size();
        double percentage = (total == 0) ? 0 : (present * 100.0 / total);

        System.out.println("Total Days: " + total);
        System.out.println("Present: " + present);
        System.out.println("Percentage: " + percentage + "%");
    }

    void monthlySummary() {
        HashMap<Integer, Integer> monthCount = new HashMap<>();

        for (Map.Entry<LocalDate, Boolean> entry : attendance.entrySet()) {
            if (entry.getValue()) {
                int month = entry.getKey().getMonthValue();
                monthCount.put(month, monthCount.getOrDefault(month, 0) + 1);
            }
        }

        System.out.println("--- Monthly Summary ---");
        for (int month : monthCount.keySet()) {
            System.out.println("Month " + month + " : " + monthCount.get(month) + " days present");
        }
    }
}

public class AttendanceSystem {

    static HashMap<Integer, Student> students = new HashMap<>();
    static Scanner sc = new Scanner(System.in);
    static int idCounter = 1;

    public static void main(String[] args) {
        int choice;

        do {
            System.out.println("\n--- Attendance System ---");
            System.out.println("1. Add Student");
            System.out.println("2. Mark Attendance");
            System.out.println("3. View Report");
            System.out.println("4. Monthly Summary");
            System.out.println("5. Save to File");
            System.out.println("0. Exit");

            choice = sc.nextInt();

            switch (choice) {
                case 1: addStudent(); break;
                case 2: markAttendance(); break;
                case 3: viewReport(); break;
                case 4: monthlySummary(); break;
                case 5: saveToFile(); break;
                case 0: System.out.println("Exiting..."); break;
                default: System.out.println("Invalid choice!");
            }

        } while (choice != 0);
    }

    static void addStudent() {
        sc.nextLine();
        System.out.print("Enter name: ");
        String name = sc.nextLine();

        Student s = new Student(idCounter, name);
        students.put(idCounter, s);

        System.out.println("Student added with ID: " + idCounter);
        idCounter++;
    }

    static void markAttendance() {
        System.out.print("Enter student ID: ");
        int id = sc.nextInt();

        Student s = students.get(id);
        if (s == null) {
            System.out.println("Student not found!");
            return;
        }

        System.out.print("Present? (true/false): ");
        boolean present = sc.nextBoolean();

        s.markAttendance(present);
        System.out.println("Attendance marked!");
    }

    static void viewReport() {
        System.out.print("Enter student ID: ");
        int id = sc.nextInt();

        Student s = students.get(id);
        if (s == null) {
            System.out.println("Student not found!");
            return;
        }

        s.showReport();
    }

    static void monthlySummary() {
        System.out.print("Enter student ID: ");
        int id = sc.nextInt();

        Student s = students.get(id);
        if (s == null) {
            System.out.println("Student not found!");
            return;
        }

        s.monthlySummary();
    }

    static void saveToFile() {
        try (BufferedWriter bw = new BufferedWriter(new FileWriter("attendance.txt"))) {
            for (Student s : students.values()) {
                bw.write("ID: " + s.id + ", Name: " + s.name);
                bw.newLine();

                for (Map.Entry<LocalDate, Boolean> entry : s.attendance.entrySet()) {
                    bw.write(entry.getKey() + " : " + entry.getValue());
                    bw.newLine();
                }
                bw.newLine();
            }
            System.out.println("Data saved!");
        } catch (IOException e) {
            System.out.println("File error!");
        }
    }
}
