import java.io.*;
import java.util.*;

 
class Product implements Serializable {
    String name;
    double price;
    int quantity;

    Product(String name, double price, int quantity) {
        this.name = name;
        this.price = price;
        this.quantity = quantity;
    }

    double getTotal() {
        return price * quantity;
    }
}

 
class Bill implements Serializable {
    ArrayList<Product> items = new ArrayList<>();
    double discount;

    void addProduct(Product p) {
        items.add(p);
    }

    double calculateTotal() {
        double total = 0;
        for (Product p : items) {
            total += p.getTotal();
        }
        return total;
    }

    double applyDiscount() {
        double total = calculateTotal();
        return total - (total * discount / 100);
    }

    void generateBill() {
        System.out.println("\n----- BILL -----");
        for (Product p : items) {
            System.out.println(p.name + " | " + p.price + " | " + p.quantity + " | " + p.getTotal());
        }

        double total = calculateTotal();
        System.out.println("Total: " + total);
        System.out.println("Discount: " + discount + "%");
        System.out.println("Final Amount: " + applyDiscount());
    }

    void saveToFile() {
        try (ObjectOutputStream oos = new ObjectOutputStream(new FileOutputStream("invoice.dat"))) {
            oos.writeObject(this);
            System.out.println("Invoice saved successfully!");
        } catch (Exception e) {
            System.out.println("Error saving invoice");
        }
    }
}

 
public class BillingSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Bill bill = new Bill();

        while (true) {
            System.out.println("\n--- Billing System ---");
            System.out.println("1. Add Item");
            System.out.println("2. Generate Bill");
            System.out.println("3. Apply Discount");
            System.out.println("4. Save Invoice");
            System.out.println("5. Exit");

            System.out.print("Enter choice: ");
            int choice = sc.nextInt();

            switch (choice) {
                case 1:
                    sc.nextLine();
                    System.out.print("Enter product name: ");
                    String name = sc.nextLine();

                    System.out.print("Enter price: ");
                    double price = sc.nextDouble();

                    System.out.print("Enter quantity: ");
                    int qty = sc.nextInt();

                    bill.addProduct(new Product(name, price, qty));
                    System.out.println("Item added!");
                    break;

                case 2:
                    bill.generateBill();
                    break;

                case 3:
                    System.out.print("Enter discount %: ");
                    bill.discount = sc.nextDouble();
                    System.out.println("Discount applied!");
                    break;

                case 4:
                    bill.saveToFile();
                    break;

                case 5:
                    System.out.println("Exiting...");
                    return;

                default:
                    System.out.println("Invalid choice");
            }
        }
    }
}
